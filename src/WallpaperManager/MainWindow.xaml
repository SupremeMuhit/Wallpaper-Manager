<Window
    x:Class="WallpaperManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:WallpaperManager.Models"
    xmlns:local="using:WallpaperManager"
    Title="Carbon Wallpaper">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.Resources>
            <Style x:Key="SubtleButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>
        </Grid.Resources>
        <Border x:Name="MicaTintOverlay" Background="Transparent" IsHitTestVisible="False" />
        <NavigationView
            x:Name="Navigation"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
            PaneTitle="Carbon Wallpaper"
            Background="Transparent"
            SelectionChanged="Navigation_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Icon="Home" Tag="Home" IsSelected="True" />
                <NavigationViewItem Content="Library" Icon="Pictures" Tag="Library" />
                <NavigationViewItem x:Name="NsfwNavTab" Content="NSFW" Tag="NsfwTab" Visibility="Collapsed">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8D4;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Guide" Icon="Help" Tag="Guide" />
            </NavigationView.FooterMenuItems>

            <Grid Padding="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="PageTitle" Text="Home" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock x:Name="PageSubtitle" Text="Selected wallpapers from your local Wallpaper Engine library." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                        <TextBlock x:Name="EngineStatusGlyph" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="EngineStatusText" VerticalAlignment="Center" />
                        <Button x:Name="StartEngineButton" Content="Start Engine" Click="StartEngine_Click" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,24,0,0">
                    <Grid x:Name="HomePage">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="HomeCountText" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <ComboBox x:Name="HomeSortComboBox" Width="150" ItemsSource="{x:Bind HomeSortChoices}" SelectionChanged="HomeSortComboBox_SelectionChanged" />
                                <ComboBox x:Name="HomeViewComboBox" Width="150" ItemsSource="{x:Bind LibraryViewChoices}" SelectionChanged="HomeViewComboBox_SelectionChanged" />
                                <ComboBox x:Name="HomeCardSizeComboBox" Width="120" ItemsSource="{x:Bind CardSizeChoices}" SelectionChanged="CardSizeComboBox_SelectionChanged" />
                            </StackPanel>
                        </Grid>

                        <InfoBar x:Name="EmptyHomeInfo" Grid.Row="1" Margin="0,14,0,0" Severity="Informational" IsOpen="True" Title="No selected wallpapers" Message="Use the Library item menu to add wallpapers to Home." />

                        <Grid Grid.Row="2" Margin="0,14,0,0">
                            <ListView x:Name="HomeListView" ItemsSource="{x:Bind SelectedWallpapers, Mode=OneWay}" SelectionMode="None" Visibility="Collapsed" CanDragItems="True" CanReorderItems="True" AllowDrop="True" DragItemsCompleted="HomeView_DragItemsCompleted">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.Header>
                                    <Grid x:Name="HomeCompactListHeader" Padding="12,0,12,8" ColumnSpacing="14" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="Local name" Style="{StaticResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="ID" Style="{StaticResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Size" Style="{StaticResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="4" Text="Tags" Style="{StaticResource CaptionTextBlockStyle}" />
                                    </Grid>
                                </ListView.Header>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:WallpaperItem">
                                        <Border Background="{x:Bind RowBackground, Mode=OneWay}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Margin="0,4" MinHeight="{x:Bind ListRowMinHeight, Mode=OneWay}">
                                            <Grid>
                                            <Grid Padding="{x:Bind ListRowPadding, Mode=OneWay}" ColumnSpacing="16" Visibility="{x:Bind LargeListLayoutVisibility, Mode=OneWay}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Width="{x:Bind ListPreviewWidth, Mode=OneWay}" Height="{x:Bind ListPreviewHeight, Mode=OneWay}" Visibility="{x:Bind ListPreviewVisibility, Mode=OneWay}" PointerEntered="PreviewImage_PointerEntered" PointerExited="PreviewImage_PointerExited">
                                                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6">
                                                        <Image Source="{x:Bind PreviewImage}" Stretch="UniformToFill" Opacity="{x:Bind BlurOpacity, Mode=OneWay}" />
                                                    </Border>
                                                    <Grid Visibility="{x:Bind BlurOverlayVisibility, Mode=OneWay}">
                                                        <Border CornerRadius="6">
                                                            <Border.Background>
                                                                <AcrylicBrush TintColor="Black" TintOpacity="{x:Bind CensorshipOverlayOpacity, Mode=OneWay}" FallbackColor="#AA000000" />
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                    <Grid Visibility="{x:Bind NsfwOverlayVisibility, Mode=OneWay}">
                                                        <Border Background="Black" Opacity="{x:Bind CensorshipOverlayOpacity, Mode=OneWay}" CornerRadius="6" />
                                                    </Grid>
                                                    <Grid Visibility="{x:Bind MatureOverlayVisibility, Mode=OneWay}">
                                                        <Border Background="Black" Opacity="{x:Bind CensorshipOverlayOpacity, Mode=OneWay}" CornerRadius="6" />
                                                    </Grid>
                                                </Grid>
                                                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}" FontSize="{x:Bind ListTitleFontSize, Mode=OneWay}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal" Spacing="22" Visibility="{x:Bind ListDetailsVisibility, Mode=OneWay}">
                                                        <TextBlock Text="{x:Bind IdText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{x:Bind SizeText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                        <TextBlock Text="{x:Bind TagsText, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <Grid Grid.Column="2" ColumnSpacing="8" RowSpacing="8" VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Button Grid.Row="0" Grid.Column="1" Visibility="{x:Bind Button1Visibility, Mode=OneWay}" Tag="{x:Bind Button1Id, Mode=OneWay}" Click="DynamicCardButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="6" Width="36" Height="36" ToolTipService.ToolTip="{x:Bind Button1Tooltip, Mode=OneWay}">
                                                        <FontIcon Glyph="{x:Bind Button1Glyph, Mode=OneWay}" FontSize="16" />
                                                    </Button>
                                                    <Button Grid.Row="1" Grid.Column="1" Visibility="{x:Bind Button2Visibility, Mode=OneWay}" Tag="{x:Bind Button2Id, Mode=OneWay}" Click="DynamicCardButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="6" Width="36" Height="36" ToolTipService.ToolTip="{x:Bind Button2Tooltip, Mode=OneWay}">
                                                        <FontIcon Glyph="{x:Bind Button2Glyph, Mode=OneWay}" FontSize="16" />
                                                    </Button>
                                                    <Button Grid.Row="2" Grid.Column="1" Visibility="{x:Bind Button3Visibility, Mode=OneWay}" Tag="{x:Bind Button3Id, Mode=OneWay}" Click="DynamicCardButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="6" Width="36" Height="36" ToolTipService.ToolTip="{x:Bind Button3Tooltip, Mode=OneWay}">
                                                        <FontIcon Glyph="{x:Bind Button3Glyph, Mode=OneWay}" FontSize="16" />
                                                    </Button>
                                                    <Button Grid.Row="0" Grid.Column="0" Visibility="{x:Bind Button4Visibility, Mode=OneWay}" Tag="{x:Bind Button4Id, Mode=OneWay}" Click="DynamicCardButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="6" Width="36" Height="36" ToolTipService.ToolTip="{x:Bind Button4Tooltip, Mode=OneWay}">
                                                        <FontIcon Glyph="{x:Bind Button4Glyph, Mode=OneWay}" FontSize="16" />
                                                    </Button>
                                                    <Button Grid.Row="1" Grid.Column="0" Visibility="{x:Bind Button5Visibility, Mode=OneWay}" Tag="{x:Bind Button5Id, Mode=OneWay}" Click="DynamicCardButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="6" Width="36" Height="36" ToolTipService.ToolTip="{x:Bind Button5Tooltip, Mode=OneWay}">
                                                        <FontIcon Glyph="{x:Bind Button5Glyph, Mode=OneWay}" FontSize="16" />
                                                    </Button>
                                                    <Button Grid.Row="2" Grid.Column="0" Visibility="{x:Bind Button6Visibility, Mode=OneWay}" Tag="{x:Bind Button6Id, Mode=OneWay}" Click="DynamicCardButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="6" Width="36" Height="36" ToolTipService.ToolTip="{x:Bind Button6Tooltip, Mode=OneWay}">
                                                        <FontIcon Glyph="{x:Bind Button6Glyph, Mode=OneWay}" FontSize="16" />
                                                    </Button>
                                                </Grid>
                                            </Grid>
                                            <Grid Padding="{x:Bind ListRowPadding, Mode=OneWay}" ColumnSpacing="14" Visibility="{x:Bind CompactListLayoutVisibility, Mode=OneWay}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="180" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Width="{x:Bind ListPreviewWidth, Mode=OneWay}" Height="{x:Bind ListPreviewHeight, Mode=OneWay}" Visibility="{x:Bind ListPreviewVisibility, Mode=OneWay}" PointerEntered="PreviewImage_PointerEntered" PointerExited="PreviewImage_PointerExited">
                                                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="4">
                                                        <Image Source="{x:Bind PreviewImage}" Stretch="UniformToFill" Opacity="{x:Bind BlurOpacity, Mode=OneWay}" />
                                                    </Border>
                                                    <Grid Visibility="{x:Bind BlurOverlayVisibility, Mode=OneWay}" Opacity="{x:Bind CensorshipOverlayOpacity, Mode=OneWay}">
                                                        <Border CornerRadius="4">
                                                            <Border.Background>
                                                                <AcrylicBrush TintColor="White" TintOpacity="0.05" TintLuminosityOpacity="0.9" FallbackColor="Transparent" />
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                    <Grid Visibility="{x:Bind NsfwOverlayVisibility, Mode=OneWay}">
                                                        <Border Background="Black" Opacity="{x:Bind CensorshipOverlayOpacity, Mode=OneWay}" CornerRadius="4" />
                                                    </Grid>
                                                    <Grid Visibility="{x:Bind MatureOverlayVisibility, Mode=OneWay}">
                                                        <Border Background="Black" Opacity="{x:Bind CensorshipOverlayOpacity, Mode=OneWay}" CornerRadius="4" />
                                                    </Grid>
                                                </Grid>
                                                <TextBlock Grid.Column="1" Text="{x:Bind DisplayName, Mode=OneWay}" FontSize="{x:Bind ListTitleFontSize, Mode=OneWay}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Visibility="{x:Bind LocalNameColumnVisibility, Mode=OneWay}" />
                                                <TextBlock Grid.Column="2" Text="{x:Bind IdText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="3" Text="{x:Bind SizeText}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="4" Text="{x:Bind TagsText, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <Button Visibility="{x:Bind Button3Visibility, Mode=OneWay}" Tag="{x:Bind Button3Id, Mode=OneWay}" Click="DynamicCardButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="6" Width="32" Height="32" ToolTipService.ToolTip="{x:Bind Button3Tooltip, Mode=OneWay}">
                                                        <FontIcon Glyph="{x:Bind Button3Glyph, Mode=OneWay}" FontSize="12" />
                                                    </Button>
                                                    <Button Visibility="{x:Bind Button2Visibility, Mode=OneWay}" Tag="{x:Bind Button2Id, Mode=OneWay}" Click="DynamicCardButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="6" Width="32" Height="32" ToolTipService.ToolTip="{x:Bind Button2Tooltip, Mode=OneWay}">
                                                        <FontIcon Glyph="{x:Bind Button2Glyph, Mode=OneWay}" FontSize="12" />
                                                    </Button>
                                                    <Button Visibility="{x:Bind Button1Visibility, Mode=OneWay}" Tag="{x:Bind Button1Id, Mode=OneWay}" Click="DynamicCardButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="6" Width="32" Height="32" ToolTipService.ToolTip="{x:Bind Button1Tooltip, Mode=OneWay}">
                                                        <FontIcon Glyph="{x:Bind Button1Glyph, Mode=OneWay}" FontSize="12" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <GridView x:Name="HomeThumbnailView" ItemsSource="{x:Bind SelectedWallpapers, Mode=OneWay}" SelectionMode="None" CanDragItems="True" CanReorderItems="True" AllowDrop="True" DragItemsCompleted="HomeView_DragItemsCompleted">
                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="models:WallpaperItem">
                                        <Border Width="{x:Bind CardWidth, Mode=OneWay}" Padding="12" Background="{x:Bind RowBackground, Mode=OneWay}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                                            <Grid>
                                            <StackPanel Spacing="10">
                                                <Grid Height="{x:Bind CardPreviewHeight, Mode=OneWay}" PointerEntered="PreviewImage_PointerEntered" PointerExited="PreviewImage_PointerExited">
                                                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6">
                                                        <Image Source="{x:Bind PreviewImage}" Stretch="UniformToFill" Opacity="{x:Bind BlurOpacity, Mode=OneWay}" />
                                                    </Border>
                                                    <Grid Visibility="{x:Bind BlurOverlayVisibility, Mode=OneWay}" Opacity="{x:Bind CensorshipOverlayOpacity, Mode=OneWay}">
                                                        <Border CornerRadius="6">
                                                            <Border.Background>
                                                                <AcrylicBrush TintColor="White" TintOpacity="0.05" TintLuminosityOpacity="0.9" FallbackColor="Transparent" />
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                    <Grid Visibility="{x:Bind NsfwOverlayVisibility, Mode=OneWay}">
                                                        <Border Background="Black" Opacity="{x:Bind CensorshipOverlayOpacity, Mode=OneWay}" CornerRadius="6" />
                                                    </Grid>
                                                    <Grid Visibility="{x:Bind MatureOverlayVisibility, Mode=OneWay}">
                                                        <Border Background="Black" Opacity="{x:Bind CensorshipOverlayOpacity, Mode=OneWay}" CornerRadius="6" />
                                                    </Grid>
                                                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="6" Padding="6" Width="32" Height="32" Style="{StaticResource SubtleButtonStyle}" CornerRadius="4" Tag="ThreeDot" Click="DynamicCardButton_Click" ToolTipService.ToolTip="More actions">
                                                        <FontIcon Glyph="&#xE712;" FontSize="12" />
                                                    </Button>
                                                </Grid>
                                                <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap" />
                                                <Grid ColumnSpacing="8" Visibility="{x:Bind ThumbnailDetailsVisibility, Mode=OneWay}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{x:Bind IdText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{x:Bind SizeText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <Button Grid.Column="2" Content="USE" Click="RunWallpaper_Click" />
                                                </Grid>
                                            </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </Grid>
                    </Grid>

                    <Grid x:Name="LibraryPage" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LibraryCountText" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button MinHeight="36" Click="ScanLibrary_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE72C;" FontSize="15" />
                                        <TextBlock Text="Scan" />
                                    </StackPanel>
                                </Button>
                                <ComboBox x:Name="LibrarySortComboBox" Width="150" ItemsSource="{x:Bind LibrarySortChoices}" SelectionChanged="LibrarySortComboBox_SelectionChanged" />
                                <ComboBox x:Name="LibraryViewComboBox" Width="150" ItemsSource="{x:Bind LibraryViewChoices}" SelectionChanged="LibraryViewComboBox_SelectionChanged" />
                                <ComboBox x:Name="CardSizeComboBox" Width="120" ItemsSource="{x:Bind CardSizeChoices}" SelectionChanged="CardSizeComboBox_SelectionChanged" />
                            </StackPanel>
                        </Grid>

                        <InfoBar x:Name="EmptyLibraryInfo" Grid.Row="1" Margin="0,14,0,0" Severity="Informational" IsOpen="True" Title="No wallpapers found" Message="Add wallpaper directories in Settings, then scan the library." />

                        <Grid Grid.Row="2" Margin="0,14,0,0">
                            <Grid x:Name="LibraryListView">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid x:Name="LibraryCompactListHeader" Padding="12,0,12,8" ColumnSpacing="14" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="PreviewHeaderColumn" Width="104" />
                                        <ColumnDefinition x:Name="LocalNameHeaderColumn" Width="2*" />
                                        <ColumnDefinition x:Name="IdHeaderColumn" Width="140" />
                                        <ColumnDefinition x:Name="SizeHeaderColumn" Width="110" />
                                        <ColumnDefinition x:Name="TagsHeaderColumn" Width="180" />
                                        <ColumnDefinition Width="56" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="PreviewHeader" Text="Preview" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBlock x:Name="LocalNameHeader" Grid.Column="1" Text="Local name" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBlock x:Name="IdHeader" Grid.Column="2" Text="ID" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBlock x:Name="SizeHeader" Grid.Column="3" Text="Size" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBlock x:Name="TagsHeader" Grid.Column="4" Text="Tags" Style="{StaticResource CaptionTextBlockStyle}" />
                                </Grid>
                                <ListView ItemsSource="{x:Bind VisibleWallpapers, Mode=OneWay}" Grid.Row="1" SelectionMode="None">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:WallpaperItem">
                                            <Border Background="{x:Bind RowBackground, Mode=OneWay}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Margin="0,4" MinHeight="{x:Bind ListRowMinHeight, Mode=OneWay}">
                                                <Grid>
                                                <Grid Padding="{x:Bind ListRowPadding, Mode=OneWay}" ColumnSpacing="16" Visibility="{x:Bind LargeListLayoutVisibility, Mode=OneWay}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Width="{x:Bind ListPreviewWidth, Mode=OneWay}" Height="{x:Bind ListPreviewHeight, Mode=OneWay}" Visibility="{x:Bind ListPreviewVisibility, Mode=OneWay}" PointerEntered="PreviewImage_PointerEntered" PointerExited="PreviewImage_PointerExited">
                                                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6">
                                                            <Image Source="{x:Bind PreviewImage}" Stretch="UniformToFill" Opacity="{x:Bind BlurOpacity, Mode=OneWay}" />
                                                        </Border>
                                                    <Grid Visibility="{x:Bind BlurOverlayVisibility, Mode=OneWay}" Opacity="{x:Bind CensorshipOverlayOpacity, Mode=OneWay}">
                                                        <Border CornerRadius="6">
                                                            <Border.Background>
                                                                <AcrylicBrush TintColor="White" TintOpacity="0.05" TintLuminosityOpacity="0.9" FallbackColor="Transparent" />
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                        <Grid Visibility="{x:Bind NsfwOverlayVisibility, Mode=OneWay}">
                                                            <Border Background="Black" Opacity="{x:Bind CensorshipOverlayOpacity, Mode=OneWay}" CornerRadius="6" />
                                                        </Grid>
                                                        <Grid Visibility="{x:Bind MatureOverlayVisibility, Mode=OneWay}">
                                                            <Border Background="Black" Opacity="{x:Bind CensorshipOverlayOpacity, Mode=OneWay}" CornerRadius="6" />
                                                        </Grid>
                                                    </Grid>
                                                    <StackPanel Grid.Column="1" Spacing="14" VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}" FontSize="{x:Bind ListTitleFontSize, Mode=OneWay}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                        <Grid ColumnSpacing="34">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="170" />
                                                                <ColumnDefinition Width="110" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Spacing="2">
                                                                <TextBlock Text="ID" Style="{StaticResource CaptionTextBlockStyle}" />
                                                                <TextBlock Text="{x:Bind IdText}" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Spacing="2">
                                                                <TextBlock Text="Size" Style="{StaticResource CaptionTextBlockStyle}" />
                                                                <TextBlock Text="{x:Bind SizeText}" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2" Spacing="2">
                                                                <TextBlock Text="Tags" Style="{StaticResource CaptionTextBlockStyle}" />
                                                                <TextBlock Text="{x:Bind TagsText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </StackPanel>
                                                <Grid Grid.Column="2" ColumnSpacing="8" RowSpacing="8" VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Button Grid.Row="0" Grid.Column="1" Visibility="{x:Bind Button1Visibility, Mode=OneWay}" Tag="{x:Bind Button1Id, Mode=OneWay}" Click="DynamicCardButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="6" Width="36" Height="36" ToolTipService.ToolTip="{x:Bind Button1Tooltip, Mode=OneWay}">
                                                        <FontIcon Glyph="{x:Bind Button1Glyph, Mode=OneWay}" FontSize="16" />
                                                    </Button>
                                                    <Button Grid.Row="1" Grid.Column="1" Visibility="{x:Bind Button2Visibility, Mode=OneWay}" Tag="{x:Bind Button2Id, Mode=OneWay}" Click="DynamicCardButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="6" Width="36" Height="36" ToolTipService.ToolTip="{x:Bind Button2Tooltip, Mode=OneWay}">
                                                        <FontIcon Glyph="{x:Bind Button2Glyph, Mode=OneWay}" FontSize="16" />
                                                    </Button>
                                                    <Button Grid.Row="2" Grid.Column="1" Visibility="{x:Bind Button3Visibility, Mode=OneWay}" Tag="{x:Bind Button3Id, Mode=OneWay}" Click="DynamicCardButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="6" Width="36" Height="36" ToolTipService.ToolTip="{x:Bind Button3Tooltip, Mode=OneWay}">
                                                        <FontIcon Glyph="{x:Bind Button3Glyph, Mode=OneWay}" FontSize="16" />
                                                    </Button>
