                                <StackPanel Spacing="5">
                                    <Grid Padding="18,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="18"><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><FontIcon Glyph="&#xE9CE;" FontSize="18" VerticalAlignment="Center" /><StackPanel Grid.Column="1" Spacing="2"><TextBlock Text="Remove Censor on Hover" FontSize="17" /><TextBlock Text="Temporarily hide censorship overlay when hovering over a wallpaper" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></StackPanel><ToggleSwitch x:Name="RemoveCensorOnHoverToggle" Grid.Column="2" Toggled="RemoveCensorOnHoverToggle_Toggled" /></Grid>
                                    <Grid Padding="18,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="18"><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><FontIcon Glyph="&#xE7C5;" FontSize="18" VerticalAlignment="Center" /><StackPanel Grid.Column="1" Spacing="2"><TextBlock Text="Automark NSFW/mature from workshop" FontSize="17" /><TextBlock Text="Automatically tag wallpapers based on Steam metadata" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></StackPanel><ToggleSwitch x:Name="AutoMarkNsfwToggle" Grid.Column="2" Toggled="AutoMarkNsfwToggle_Toggled" /></Grid>
                                    <Grid Padding="18,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="18"><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><FontIcon Glyph="&#xE8D4;" FontSize="18" VerticalAlignment="Center" /><StackPanel Grid.Column="1" Spacing="2"><TextBlock Text="NSFW censorship mode" FontSize="17" /><TextBlock Text="How NSFW wallpapers are censored" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></StackPanel><ComboBox x:Name="NsfwModeComboBox" Grid.Column="2" Width="160" SelectionChanged="NsfwModeComboBox_SelectionChanged"><x:String>Off</x:String><x:String>Blur</x:String><x:String>Overlay</x:String></ComboBox></Grid>
                                    <Grid Padding="18,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="18"><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><FontIcon Glyph="&#xE8D4;" FontSize="18" VerticalAlignment="Center" /><StackPanel Grid.Column="1" Spacing="2"><TextBlock Text="Mature censorship mode" FontSize="17" /><TextBlock Text="How Mature wallpapers are censored" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></StackPanel><ComboBox x:Name="MatureModeComboBox" Grid.Column="2" Width="160" SelectionChanged="MatureModeComboBox_SelectionChanged"><x:String>Off</x:String><x:String>Blur</x:String><x:String>Overlay</x:String></ComboBox></Grid>
                                    <Grid Padding="18,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="18"><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><FontIcon Glyph="&#xE9E9;" FontSize="18" VerticalAlignment="Center" /><StackPanel Grid.Column="1" Spacing="2"><TextBlock Text="Blur intensity" FontSize="17" /><TextBlock Text="Adjust the fading/blur effect for preview images" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></StackPanel><Slider x:Name="BlurIntensitySlider" Grid.Column="2" Width="200" Minimum="0" Maximum="100" StepFrequency="5" ValueChanged="BlurIntensitySlider_ValueChanged" /></Grid>
                                    <Grid Padding="18,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="18"><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><FontIcon Glyph="&#xE9E9;" FontSize="18" VerticalAlignment="Center" /><StackPanel Grid.Column="1" Spacing="2"><TextBlock Text="Overlay opacity" FontSize="17" /><TextBlock Text="Adjust darkness of the censorship overlay" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></StackPanel><Slider x:Name="OverlayOpacitySlider" Grid.Column="2" Width="200" Minimum="0" Maximum="1" StepFrequency="0.05" ValueChanged="OverlayOpacitySlider_ValueChanged" /></Grid>
                                    <!-- Censorship Previews -->
                                    <Grid Padding="18,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="18">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE8B9;" FontSize="18" VerticalAlignment="Top" Margin="0,6,0,0" />
                                        <StackPanel Grid.Column="1" Spacing="12">
                                            <TextBlock Text="Censorship Preview" FontSize="17" />
                                            <StackPanel Orientation="Horizontal" Spacing="24">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="NSFW" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                                    <Border Width="160" Height="90" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                                                        <Grid>
                                                            <Image Source="{x:Bind NsfwPreviewItem.PreviewImage, Mode=OneWay}" Stretch="UniformToFill" Opacity="{x:Bind NsfwPreviewItem.BlurOpacity, Mode=OneWay}" />
                                                            <Grid Visibility="{x:Bind NsfwPreviewItem.BlurOverlayVisibility, Mode=OneWay}" Opacity="{x:Bind NsfwPreviewItem.CensorshipOverlayOpacity, Mode=OneWay}"><Border CornerRadius="6"><Border.Background><AcrylicBrush TintColor="White" TintOpacity="0.01" TintLuminosityOpacity="0" FallbackColor="Transparent" /></Border.Background></Border></Grid>
                                                            <Grid Visibility="{x:Bind NsfwPreviewItem.NsfwOverlayVisibility, Mode=OneWay}">
                                                                <Border Background="Black" Opacity="{x:Bind NsfwPreviewItem.CensorshipOverlayOpacity, Mode=OneWay}" CornerRadius="6" />
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Mature" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                                    <Border Width="160" Height="90" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                                                        <Grid>
                                                            <Image Source="{x:Bind MaturePreviewItem.PreviewImage, Mode=OneWay}" Stretch="UniformToFill" Opacity="{x:Bind MaturePreviewItem.BlurOpacity, Mode=OneWay}" />
                                                            <Grid Visibility="{x:Bind MaturePreviewItem.BlurOverlayVisibility, Mode=OneWay}" Opacity="{x:Bind MaturePreviewItem.CensorshipOverlayOpacity, Mode=OneWay}"><Border CornerRadius="6"><Border.Background><AcrylicBrush TintColor="White" TintOpacity="0.01" TintLuminosityOpacity="0" FallbackColor="Transparent" /></Border.Background></Border></Grid>
                                                            <Grid Visibility="{x:Bind MaturePreviewItem.MatureOverlayVisibility, Mode=OneWay}">
                                                                <Border Background="Black" Opacity="{x:Bind MaturePreviewItem.CensorshipOverlayOpacity, Mode=OneWay}" CornerRadius="6" />
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="TagSettingsPanel" Visibility="Collapsed" Spacing="20">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Tags" FontSize="28" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Spacing="5">
                                    <Grid Padding="18,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="18"><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><FontIcon Glyph="&#xE8EC;" FontSize="18" VerticalAlignment="Center" /><StackPanel Grid.Column="1" Spacing="2"><TextBlock Text="Use Workshop Tags" FontSize="17" /><TextBlock Text="Show workshop tags alongside local tags" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></StackPanel><ToggleSwitch x:Name="UseWorkshopTagsToggle" Grid.Column="2" Toggled="UseWorkshopTagsToggle_Toggled" /></Grid>
                                    <Grid Padding="18,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="TagSearchTextBox" PlaceholderText="Search tag" TextChanged="TagSearchTextBox_TextChanged" /><Button Grid.Column="1" Click="CreateTag_Click"><FontIcon Glyph="&#xE710;" /></Button></Grid>
                                    <ListView x:Name="TagsListView" ItemsSource="{x:Bind VisibleTags, Mode=OneWay}" SelectionMode="None" CanDragItems="True" CanReorderItems="True" AllowDrop="True" DragItemsCompleted="TagsListView_DragItemsCompleted">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,5,0,0" />
                                                <Setter Property="MinHeight" Value="0" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="models:WallpaperTag">
                                                <Grid Padding="18,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                    <FontIcon Glyph="&#xE700;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                    <Border Grid.Column="1" Width="22" Height="22" CornerRadius="4" Background="{x:Bind ColorBrush}" />
                                                    <TextBlock Grid.Column="2" Text="{x:Bind Name}" VerticalAlignment="Center" FontSize="20" />
                                                    <Button Grid.Column="3" Click="EditTagButton_Click"><FontIcon Glyph="&#xE713;" /></Button>
                                                    <Button Grid.Column="4" Click="RemoveTag_Click"><FontIcon Glyph="&#xE74D;" /></Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="AboutSettingsPanel" Visibility="Collapsed" Spacing="20">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="About" FontSize="28" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Spacing="5">
                                    <Grid Padding="18,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="18"><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><FontIcon Glyph="&#xE946;" FontSize="18" VerticalAlignment="Center" /><StackPanel Grid.Column="1" Spacing="2"><TextBlock Text="App Name + Version" FontSize="17" /><TextBlock Text="Carbon Wallpaper - Prerelease V1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" /></StackPanel></Grid>
                                    <Grid Padding="18,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="18"><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><FontIcon Glyph="&#xE77B;" FontSize="18" VerticalAlignment="Center" /><Image Grid.Column="1" Width="72" Height="72" Stretch="UniformToFill" Source="https://github.com/SupremeMuhit.png" /><StackPanel Grid.Column="2" Spacing="2"><TextBlock Text="Dev Detail" FontSize="17" /><Button HorizontalAlignment="Left" Content="GitHub: SupremeMuhit" Tag="https://github.com/SupremeMuhit" Click="OpenExternalLink_Click" /><Button HorizontalAlignment="Left" Content="Discord Profile" Tag="https://discord.com/users/1341440502104592507" Click="OpenExternalLink_Click" /></StackPanel></Grid>
                                    <Grid Padding="18,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="18"><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><FontIcon Glyph="&#xE8F1;" FontSize="18" VerticalAlignment="Center" /><StackPanel Grid.Column="1" Spacing="2"><TextBlock Text="Acknowledgements" FontSize="17" /><TextBlock Text="Built with WinUI and Windows App SDK. Thanks to Wallpaper Engine and all open source dependencies used by this project." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" /></StackPanel></Grid>

                                    <Grid Padding="18,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="18"><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><FontIcon Glyph="&#xE72E;" FontSize="18" VerticalAlignment="Center" /><StackPanel Grid.Column="1" Spacing="2"><TextBlock Text="License" FontSize="17" /><TextBlock Text="Open source license will be added later." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" /></StackPanel></Grid>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel x:Name="ContactSettingsPanel" Visibility="Collapsed" Spacing="20">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Contact" FontSize="28" FontWeight="SemiBold" />
                                </StackPanel>
                                <Grid Padding="18,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="18"><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><FontIcon Glyph="&#xE715;" FontSize="18" VerticalAlignment="Top" Margin="0,6,0,0" /><StackPanel Grid.Column="1" Spacing="12"><TextBlock Text="Contact Form" FontSize="17" /><Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBox x:Name="ContactMailTextBox" Header="Mail" PlaceholderText="name@example.com" /><TextBox x:Name="ContactDiscordTextBox" Grid.Column="1" Header="Discord username" PlaceholderText="username" /></Grid><TextBox x:Name="ContactMessageTextBox" Header="Message" PlaceholderText="Write your message" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="130" MaxLength="1500" /><StackPanel Orientation="Horizontal" Spacing="10"><Button x:Name="SendContactButton" Content="Send" Click="SendContact_Click" /><ProgressRing x:Name="ContactProgressRing" Width="28" Height="28" IsActive="False" Visibility="Collapsed" /></StackPanel><InfoBar x:Name="ContactInfoBar" IsOpen="False" /></StackPanel></Grid>
                            </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Window>






